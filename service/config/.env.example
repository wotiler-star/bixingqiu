# 币星球 数据库连接配置示例
# 用法：复制本文件为同目录下的 .env，填入真实值（.env 不要提交到版本库）
# 服务启动时由 config/dbconn.php 自动读取

# 数据库主机（Vultr 上一般是 localhost，若数据库在其它实例则填对应 IP）
DB_HOST=localhost
# 数据库端口
DB_PORT=3306
# 数据库名
DB_NAME=k_k3_bixingqiu
# 数据库用户名（不要再用 root/空密码，建议新建专用账号）
DB_USER=bixingqiu
# 数据库密码
DB_PASS=请改成强密码

# 可选：限制允许访问本站点的主机名（留空=不限制，便于部署到任意服务器/IP）
BXQ_ALLOWED_HOST=
# 可选：调试模式 1=开启报错显示  0=关闭（生产环境务必设为 0）
BXQ_DEBUG=0
